{
  "name": "directus-extension-queryable-formula",
  "version": "1.0.2",
  "description": "Formula field that stores computed values in DB for querying",
  "icon": "extension",
  "license": "MIT",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-bundle",
    "directus-formula"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "sandboxed": true,
  "directus:extension": {
    "type": "bundle",
    "partial": false,
    "sandboxed": true,
    "host": "^11.0.0",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "entries": [
      {
        "type": "interface",
        "name": "formula-interface",
        "source": "src/formula-interface/index.ts"
      },
      {
        "type": "hook",
        "name": "formula-hook",
        "source": "src/formula-hook/index.ts"
      },
      {
        "type": "endpoint",
        "name": "queryable-formula",
        "source": "src/formula-endpoint/index.ts"
      }
    ]
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link",
    "validate": "directus-extension validate",
    "add": "directus-extension add"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "17.0.10",
    "typescript": "^5.9.3",
    "vue": "^3.5.29",
    "@types/node": "^25.3.5"
  }
}
