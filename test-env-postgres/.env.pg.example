# Optional overrides for test-env-postgres (copy to .env.pg).
#
# ─── Default (omit this file or leave USE_EXTERNAL_POSTGRES unset) ───
# Postgres runs in Docker (docker-compose.yml). Directus uses 127.0.0.1:54322.
# Requires: Docker. No local Postgres or psql needed for setup if you skip the optional check.
#
# ─── External Postgres ───
# USE_EXTERNAL_POSTGRES=1
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=directus
# PGPASSWORD=directus
# PGDATABASE=directus_formula_test
#
# Create DB/user first, e.g.:
#   createdb -h 127.0.0.1 -U postgres directus_formula_test

# USE_EXTERNAL_POSTGRES=0

# Directus HTTP (both modes; parallel to SQLite test env on 8055)
DIRECTUS_PORT=8056
DIRECTUS_PUBLIC_URL=http://localhost:8056
